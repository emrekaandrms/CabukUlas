# Terminalden Supabase veritabani komutlari icin
# Tek satir connection string tercih edilir:
# SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# Alternatif olarak ayri alanlar da kullanabilirsiniz:
# SUPABASE_DB_HOST=db.your-project-ref.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_DB_NAME=postgres
