{
  "expo": {
    "name": "CabukUlas",
    "slug": "CabukUlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "cabukulas",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F8F6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cabukulas.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F8F6"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.cabukulas.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b7575814-170f-47ad-a96e-ace9f3cb5b68"
      }
    }
  }
}
